# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/lunar-hr

# ─── Auth ────────────────────────────────────────────────────────────────────
# Any long random string — used to sign/verify session JWTs
JWT_SECRET=change-me-to-a-long-random-string

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/oauth/google/callback
VITE_GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ─── LLM (HR Chatbot) ────────────────────────────────────────────────────────
# Any OpenAI-compatible API. Examples:
#   OpenAI:    https://api.openai.com
#   Anthropic: https://api.anthropic.com  (use claude-* model in llm.ts)
BUILT_IN_FORGE_API_URL=https://api.openai.com
BUILT_IN_FORGE_API_KEY=your-llm-api-key

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_TITLE=Lunar-HR

# Your full public URL — used to build the Google OAuth redirect URI.
# Development: leave blank (auto-detected as http://localhost:3000)
# Production:  set to your exact domain e.g. https://lunar-hr.yourdomain.com
APP_URL=
